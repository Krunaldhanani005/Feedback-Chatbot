# ═══════════════════════════════════════════════════════
#  NANTA TECH EXPERIENCE DAYS — ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your values.
#  Never commit .env to git — it is already in .gitignore
# ═══════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────
# Development: SQLite (simple, zero-setup)
DATABASE_URL="file:./dev.db"
# Production (Hostinger/VPS): switch to PostgreSQL
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Admin Auth (CHANGE THESE — use random 32+ char strings) ──
ADMIN_SECRET_KEY="change-this-to-a-random-32-char-string-abc123"
NEXTAUTH_SECRET="change-this-to-another-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Admin Login Credentials ──────────────────────────────
ADMIN_EMAIL="admin@nantatech.com"
ADMIN_PASSWORD="ChangeThisPassword123!"

# ── AI Provider ──────────────────────────────────────────
# To switch provider: change AI_PROVIDER + set the matching API key
# Options: groq | claude | openai | rule-based
AI_PROVIDER="groq"

# ── Groq (recommended — fast, free tier available) ───────
# Get key at: https://console.groq.com
GROQ_API_KEY="your-groq-api-key-here"
GROQ_MODEL="llama-3.3-70b-versatile"

# ── Claude / Anthropic (alternative) ─────────────────────
# Get key at: https://console.anthropic.com
# Set AI_PROVIDER=claude to activate
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-sonnet-4-6"

# ── OpenAI (alternative) ─────────────────────────────────
# Get key at: https://platform.openai.com
# Set AI_PROVIDER=openai to activate
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# ── App Settings ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Nanta Tech Experience Days"
NEXT_PUBLIC_COMPANY_NAME="Nanta Tech Limited"

# ── Hostinger Deployment ─────────────────────────────────
# Set both to true when building for Hostinger VPS
BUILD_STANDALONE="false"
HOSTINGER="false"
