# Database
DATABASE_URL="file:./dev.db"

# Auth
ADMIN_SECRET_KEY="your-secret-key-min-32-chars-change-this-in-production"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Admin Credentials (set these before first run)
ADMIN_EMAIL="admin@nantatech.com"
ADMIN_PASSWORD="Admin@123!"

# AI Provider (options: rule-based, claude, openai, gemini)
AI_PROVIDER="rule-based"
AI_MODEL=""

# Claude (Anthropic)
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-sonnet-4-6"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Gemini
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Inogration AI Assistant"
NEXT_PUBLIC_COMPANY_NAME="Nanta Tech Limited"

# Deployment
BUILD_STANDALONE="false"
HOSTINGER="false"
